#!/usr/bin/env bash

# Изменить размер изображения до указанной ширины.
# Высоту установить пропорционально.
# Требует установленного imagemagick.

set -euo pipefail

file="${1:?Usage: $0 <image> <width>}"
width="${2:?Usage: $0 <image> <width>}"

output="${file%.*}-${width}w.${file##*.}"

magick "$file" -resize "${width}x" "$output"

echo "Created: $output"