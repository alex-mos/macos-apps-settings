#!/usr/bin/env bash
set -euo pipefail

ROOT="${1:-.}"

if [ ! -d "$ROOT" ]; then
    echo "Ошибка: $ROOT не является директорией" >&2
    exit 1
fi

deleted=0

while IFS= read -r -d '' f; do
    rm "$f"
    echo "удалён: $f"
    ((deleted++))
done < <(find "$ROOT" -type f \( -name 'download_more_albums.html' -o -name '.sync-conflict*' \) -print0)

if [ "$deleted" -eq 0 ]; then
    echo "Ничего не найдено"
else
    echo "Удалено файлов: $deleted"
fi
