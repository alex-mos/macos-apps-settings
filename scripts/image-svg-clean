#!/usr/bin/env bash

# оптимизировать размер svg

set -euo pipefail

file="${1:?Usage: $0 <svg_file>}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
tmp="${file}.tmp.svg"

trap 'rm -f "$tmp"' EXIT

svgo --config "$script_dir/svg-clean.config.js" "$file" --output "$tmp"

xmllint --format "$tmp" --encode UTF-8 > "$file"

echo "Cleaned and formatted: $file"
