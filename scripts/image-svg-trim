#!/usr/bin/env bash

# Обрезать пустое место по краям svg, затем оптимизировать файл.
# Требует установленного inkscape.

set -euo pipefail

file="${1:?Usage: $0 <file.svg>}"
tmp="${file}.tmp.svg"

[[ -f "$file" ]] || { echo "File not found: $file"; exit 1; }

trap 'rm -f "$tmp"' EXIT

inkscape "$file" --export-area-drawing --export-filename="$tmp" &>/dev/null

mv "$tmp" "$file"

echo "Trimmed: $file"

img-svg-clean "$file"

echo "Optimized: $file"