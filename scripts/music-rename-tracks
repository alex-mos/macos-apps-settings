#!/usr/bin/env bash

# Переименовать музыкальные файлы в формат
# "track_number. track_name"

set -euo pipefail

dir="${1:-.}"

shopt -s nullglob
files=("$dir"/*.{flac,mp3,m4a,wav})
shopt -u nullglob

for f in "${files[@]}"; do
    track=$(ffprobe -v quiet -select_streams a:0 \
        -show_entries format_tags=track \
        -of default=noprint_wrappers=1:nokey=1 "$f" 2>/dev/null)
    title=$(ffprobe -v quiet -select_streams a:0 \
        -show_entries format_tags=title \
        -of default=noprint_wrappers=1:nokey=1 "$f" 2>/dev/null)

    if [[ -z "$track" || -z "$title" ]]; then
        echo "Пропускаю $f — нет тегов track или title"
        continue
    fi

    track=$(printf '%02d' "${track%%/*}")
    newname="${f%/*}/$track. $title.${f##*.}"

    if [[ "$f" != "$newname" ]]; then
        mv "$f" "$newname"
        echo "Файл переименован: $(basename "$f") -> $(basename "$newname")"
    fi
done
